{
  "name": "PSOS — Personal Strategic Operating System",
  "short_name": "PSOS",
  "description": "Maurice Muhumuza's strategic operating system, anchored on money: every project traced to where its funding comes from and where it goes.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#070B14",
